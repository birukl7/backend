# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Channel username (e.g. @myjobschannel) or numeric chat ID (e.g. -1001234567890)
# Make your bot an admin of the channel before using a username.
TELEGRAM_CHANNEL_ID=

# Public URL of the Laravel app — used to build the job deep-link
APP_URL=http://localhost:8000

# Port this service listens on (default 8002)
TELEGRAM_SERVICE_PORT=8002

# Comma-separated origins allowed to call this service (CORS)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
